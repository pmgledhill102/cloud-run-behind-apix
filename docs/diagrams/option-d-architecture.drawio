        <!-- ==================== KEY FINDINGS ==================== -->
        <mxCell id="findings" value="Traffic Flow: &#10102; PSC endpoint (10.0.0.50) in consumer VPC  &#10103; PSC tunnel crosses VPC boundary  &#10104; Service Attachment receives traffic  &#10105; ILB (10.100.0.10) routes via URL Map  &#10106; Serverless NEG selects backend  &#10107; Cloud Run service&#xa;&#xa;Pros: Strongest isolation, cross-org access control, approval-based, no VPN dependency, custom domains, full traffic control&#xa;Cons: Most complex setup, highest per-service cost (~$36/mo per group), ILB + SA per service group" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;fillColor=#FFF8E1;rounded=1;strokeColor=#F9A825;spacingLeft=10;spacingRight=10;spacingTop=6;spacingBottom=6;whiteSpace=wrap;" vertex="1" parent="1">
