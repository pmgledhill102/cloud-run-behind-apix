        <!-- Title -->
        <mxCell id="title" value="Apigee X → Cloud Run: Four Connectivity Options" style="text;html=1;fontSize=20;fontStyle=1;align=center;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Apigee VPC connected to Workloads VPC via HA VPN — which pattern should you use?" style="text;html=1;fontSize=11;align=center;fontColor=#5F6368;" vertex="1" parent="1">
          <mxGeometry x="200" y="42" width="1200" height="20" as="geometry"/>
        </mxCell>

        <!-- ==================== OPTION A ==================== -->
        <mxCell id="panel-a" value="Option A: ILB + Serverless NEG via VPN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#E65100;arcSize=4;container=1;collapsible=0;spacingTop=3;" vertex="1" parent="1">
