        <mxCell id="a-cr" value="Cloud Run" style="shape=mxgraph.gcp2.cloud_run;fillColor=#AECBFA;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=9;fontColor=#3C4043;fontStyle=1;" vertex="1" parent="panel-a">
          <mxGeometry x="290" y="40" width="50" height="40" as="geometry"/>
