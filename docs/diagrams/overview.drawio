        <!-- Option A: Details -->
        <mxCell id="a-details" value="LB Required: Yes (Internal ALB)&#xa;Traffic Path: Via VPN tunnels&#xa;DNS: A record → ILB IP&#xa;Cost: ~$91/mo (ILB + VPN)&#xa;Scale: URL map routing (2K rules/map)&#xa;VPN Dependency: Yes&#xa;&#xa;Best for: Full traffic control,&#xa;custom domains, Cloud Armor" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;whiteSpace=wrap;" vertex="1" parent="panel-a">
          <mxGeometry x="15" y="115" width="340" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="a-verdict" value="TRAFFIC CONTROL" style="text;fontSize=10;fontColor=#FFFFFF;align=center;fontStyle=1;fillColor=#E65100;rounded=1;" vertex="1" parent="panel-a">
          <mxGeometry x="95" y="330" width="180" height="24" as="geometry"/>
