          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Option C: Details -->
        <mxCell id="c-details" value="LB Required: No&#xa;Traffic Path: PSC → Google backbone (bypasses VPN)&#xa;DNS: *.run.app → PSC endpoint IP&#xa;Cost: ~$18/mo (PSC forwarding rule)&#xa;Scale: No bottleneck&#xa;VPN Dependency: No&#xa;&#xa;Best for: Enterprise governance,&#xa;VPC-SC, explicit internal IP" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;whiteSpace=wrap;" vertex="1" parent="panel-c">
