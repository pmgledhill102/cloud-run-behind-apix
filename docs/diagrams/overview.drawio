        </mxCell>
        <mxCell id="d-sa" value="Service&#xa;Attachment" style="shape=mxgraph.gcp2.cloud_endpoints;fillColor=#CE93D8;strokeColor=none;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=8;fontColor=#3C4043;fontStyle=1;" vertex="1" parent="panel-d">
