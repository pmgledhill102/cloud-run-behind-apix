        <!-- Option D: Details -->
        <mxCell id="d-details" value="LB Required: Yes (Internal ALB)&#xa;Traffic Path: PSC tunnel (bypasses VPN)&#xa;DNS: Custom domain → PSC endpoint IP&#xa;Cost: ~$36/mo (ILB + PSC)&#xa;Scale: ILB + SA per service group&#xa;VPN Dependency: No&#xa;&#xa;Best for: Cross-org isolation,&#xa;approval-based access control" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;whiteSpace=wrap;" vertex="1" parent="panel-d">
