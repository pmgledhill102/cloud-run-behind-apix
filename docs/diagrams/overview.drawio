        </mxCell>

        <!-- ==================== DECISION GUIDE ==================== -->
        <mxCell id="decision" value="Quick Decision Guide&#xa;&#xa;Need traffic control / custom domains / Cloud Armor?  →  Option A (ILB via VPN)  or  Option D (PSC Service Attachment)&#xa;Want simplest setup with lowest cost?  →  Option B (PGA)&#xa;Need enterprise governance with explicit IP?  →  Option C (PSC for Google APIs)&#xa;Need cross-org isolation with approval model?  →  Option D (PSC Service Attachment)&#xa;Scaling to 1000+ services with minimal infra?  →  Option B or C" style="text;fontSize=11;fontColor=#3C4043;align=left;verticalAlign=top;fillColor=#FFF8E1;rounded=1;strokeColor=#F9A825;spacingLeft=12;spacingRight=12;spacingTop=8;spacingBottom=8;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="470" width="1540" height="120" as="geometry"/>
        </mxCell>

        <!-- ==================== COMPARISON TABLE ==================== -->
        <mxCell id="comparison" value="                                    Option A            Option B            Option C            Option D&#xa;LB Required                    Yes                     No                      No                      Yes&#xa;VPN Dependency           Yes                     No                      No                      No&#xa;Cost (monthly)             ~$91                   ~$0.20               ~$18                   ~$36+&#xa;Scale to 1000s             Multi-ILB             No limit               No limit               Multi-ILB+SA&#xa;Traffic Control              Full                     Limited               Limited               Full" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;fillColor=#F1F3F4;rounded=1;strokeColor=#DADCE0;spacingLeft=12;spacingRight=12;spacingTop=8;spacingBottom=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="610" width="1540" height="110" as="geometry"/>
