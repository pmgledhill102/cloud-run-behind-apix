        <mxCell id="panel-b" value="Option B: Private Google Access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#2E7D32;arcSize=4;container=1;collapsible=0;spacingTop=3;" vertex="1" parent="1">
