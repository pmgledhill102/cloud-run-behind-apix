        <!-- Option B: Details -->
        <mxCell id="b-details" value="LB Required: No&#xa;Traffic Path: Google backbone (bypasses VPN)&#xa;DNS: *.run.app → restricted VIP&#xa;Cost: ~$0.20/mo (DNS only)&#xa;Scale: No bottleneck&#xa;VPN Dependency: No&#xa;&#xa;Best for: Simplest setup,&#xa;lowest cost, maximum scale" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;whiteSpace=wrap;" vertex="1" parent="panel-b">
