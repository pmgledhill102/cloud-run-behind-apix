        <!-- ==================== KEY FINDINGS ==================== -->
        <mxCell id="findings" value="Traffic Flow: &#10102; DNS resolves api.internal.example.com → ILB IP (10.100.0.10)  &#10103; Route via BGP  &#10104; HA VPN tunnel  &#10105; Workloads VPC router  &#10106; ILB → URL Map → Serverless NEG  &#10107; NEG selects backend  &#10108; Cloud Run service&#xa;&#xa;Pros: Full traffic control, path-based routing, Cloud Armor, TLS termination, custom domains&#xa;Cons: VPN tunnel dependency, ILB management overhead, regional (ILB per region)" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;fillColor=#FFF8E1;rounded=1;strokeColor=#F9A825;spacingLeft=10;spacingRight=10;spacingTop=6;spacingBottom=6;whiteSpace=wrap;" vertex="1" parent="1">
