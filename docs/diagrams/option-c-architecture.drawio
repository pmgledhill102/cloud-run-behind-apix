        <!-- ==================== KEY FINDINGS ==================== -->
        <mxCell id="findings" value="Traffic Flow: &#10102; PSC endpoint created with internal IP 10.0.0.100 → all-apis bundle  &#10103; DNS resolves *.run.app → 10.0.0.100  &#10104; PSC tunnels traffic to Google API frontend  &#10105; Cloud Run receives request&#xa;&#xa;Pros: Enterprise-grade, explicit internal IP for firewall/audit, VPC-SC compatible, no VPN dependency, no per-service infra&#xa;Cons: PSC forwarding rule cost (~$18/mo), more setup than PGA, same limited traffic management as PGA" style="text;fontSize=10;fontColor=#3C4043;align=left;verticalAlign=top;fillColor=#FFF8E1;rounded=1;strokeColor=#F9A825;spacingLeft=10;spacingRight=10;spacingTop=6;spacingBottom=6;whiteSpace=wrap;" vertex="1" parent="1">
